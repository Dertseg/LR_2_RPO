<Window x:Class="TicTacToe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Крестики-Нолики" Height="700" Width="520"
        Background="#1A1A2E" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Ресурсы приложения -->
    <Window.Resources>

        <!-- Эффект свечения -->
        <DropShadowEffect x:Key="GlowEffect" Color="#6B7FFF" BlurRadius="25" ShadowDepth="0" Opacity="0.7"/>
        <DropShadowEffect x:Key="SoftShadow" Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>

        <!-- Стиль для игровых кнопок -->
        <Style x:Key="GameButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#252542"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="64"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="20" 
                                BorderBrush="#3A3A6E" 
                                BorderThickness="2">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="3" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2D2D52"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#5A5A9E"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#6B7FFF" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F1F3A"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки рестарта -->
        <Style x:Key="RestartButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF6B8B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="Margin" Value="0,35,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource GlowEffect}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="30"
                                BorderThickness="0">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF6B8B" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF5275"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF5275" BlurRadius="30" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E63955"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Анимация пульсации для статуса -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                           From="1" To="0.7" Duration="0:0:1" AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>

    <!-- Рамка окна с закруглёнными углами -->
    <Border Background="#1A1A2E" CornerRadius="20" BorderBrush="#3A3A6E" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="#6B7FFF" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <!-- Кнопка закрытия окна -->
            <Button Content="✕" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Margin="15"
                    Width="35" Height="35"
                    Background="Transparent"
                    Foreground="#AAAAAA"
                    FontWeight="Bold"
                    FontSize="16"
                    Cursor="Hand"
                    Click="CloseButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="10" Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#FF5252"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- Заголовок с градиентом и свечением -->
                <TextBlock Text="Крестики-Нолики" 
                           FontSize="48" 
                           FontWeight="ExtraBold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,50"
                           Effect="{StaticResource GlowEffect}">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#7B68EE" Offset="0"/>
                            <GradientStop Color="#FF6B9D" Offset="0.5"/>
                            <GradientStop Color="#4ECDC4" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <!-- Индикатор хода с анимацией -->
                <Border x:Name="StatusBorder" 
                        Background="#252542" 
                        CornerRadius="20" 
                        Padding="25,15" 
                        Margin="0,0,0,40"
                        BorderBrush="#3A3A6E"
                        BorderThickness="2">
                    <Border.Effect>
                        <DropShadowEffect Color="#4ECDC4" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                    </Border.Effect>
                    <TextBlock x:Name="StatusText" 
                               Text="Ход игрока: X" 
                               FontSize="24" 
                               FontWeight="Bold"
                               HorizontalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#4ECDC4" Offset="0"/>
                                <GradientStop Color="#6B7FFF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Border>

                <!-- Игровое поле 3x3 -->
                <UniformGrid x:Name="GameGrid" Rows="3" Columns="3" Width="360" Height="360">
                    <Button x:Name="Btn00" Click="Button_Click" Style="{StaticResource GameButtonStyle}" Tag="0,0"/>
                    <Button x:Name="Btn01" Click="Button_Click" Style="{StaticResource GameButtonStyle}" Tag="0,1"/>
                    <Button x:Name="Btn02" Click="Button_Click" Style="{StaticResource GameButtonStyle}" Tag="0,2"/>

                    <Button x:Name="Btn10" Click="Button_Click" Style="{StaticResource GameButtonStyle}" Tag="1,0"/>
                    <Button x:Name="Btn11" Click="Button_Click" Style="{StaticResource GameButtonStyle}" Tag="1,1"/>
                    <Button x:Name="Btn12" Click="Button_Click" Style="{StaticResource GameButtonStyle}" Tag="1,2"/>

                    <Button x:Name="Btn20" Click="Button_Click" Style="{StaticResource GameButtonStyle}" Tag="2,0"/>
                    <Button x:Name="Btn21" Click="Button_Click" Style="{StaticResource GameButtonStyle}" Tag="2,1"/>
                    <Button x:Name="Btn22" Click="Button_Click" Style="{StaticResource GameButtonStyle}" Tag="2,2"/>
                </UniformGrid>

                <!-- Кнопка рестарта -->
                <Button Content="🔄 Начать заново" 
                        Click="Restart_Click"
                        Style="{StaticResource RestartButtonStyle}"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>